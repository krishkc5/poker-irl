rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function roomPath(roomCode) {
      return /databases/$(database)/documents/rooms/$(roomCode);
    }

    function roomExists(roomCode) {
      return exists(roomPath(roomCode));
    }

    function roomData(roomCode) {
      return get(roomPath(roomCode)).data;
    }

    function roomDataAfter(roomCode) {
      return getAfter(roomPath(roomCode)).data;
    }

    function isRoomMember(roomCode) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/rooms/$(roomCode)/players/$(request.auth.uid));
    }

    function isRoomHost(roomCode) {
      return isSignedIn()
        && roomExists(roomCode)
        && roomData(roomCode).hostUid == request.auth.uid;
    }

    match /rooms/{roomCode} {
      // Lobby room doc read is allowed for authenticated users so they can join by code.
      // Also allow reads for non-existing room docs so createRoom collision checks can run.
      allow read: if isSignedIn() && (
        !roomExists(roomCode)
        || isRoomMember(roomCode)
        || (roomExists(roomCode) && roomData(roomCode).status == 'lobby')
      );
      allow create: if isSignedIn() && request.resource.data.hostUid == request.auth.uid;
      allow update, delete: if isRoomHost(roomCode);

      match /players/{uid} {
        // Allow lobby reads so users can see seats/host and join cleanly.
        allow read: if isRoomMember(roomCode)
          || (
            isSignedIn()
            && roomExists(roomCode)
            && roomData(roomCode).status == 'lobby'
          );

        allow create: if isSignedIn()
          && request.auth.uid == uid
          && (
            (roomExists(roomCode) && roomData(roomCode).status == 'lobby')
            || (
              !roomExists(roomCode)
              && roomDataAfter(roomCode).hostUid == request.auth.uid
              && roomDataAfter(roomCode).status == 'lobby'
            )
          );

        allow update: if isSignedIn() && (request.auth.uid == uid || isRoomHost(roomCode));
        allow delete: if isSignedIn() && (request.auth.uid == uid || isRoomHost(roomCode));
      }

      match /actions/{actionId} {
        // Allow lobby action feed visibility before membership is established.
        allow read: if isRoomMember(roomCode)
          || (
            isSignedIn()
            && roomExists(roomCode)
            && roomData(roomCode).status == 'lobby'
          );
        allow create: if isRoomMember(roomCode)
          || (
            isSignedIn()
            && !roomExists(roomCode)
            && roomDataAfter(roomCode).hostUid == request.auth.uid
            && roomDataAfter(roomCode).status == 'lobby'
          );
        allow update, delete: if false;
      }

      match /hands/{handId} {
        allow read: if isRoomMember(roomCode);
        allow create: if isRoomHost(roomCode);
        allow update, delete: if false;
      }
    }
  }
}
